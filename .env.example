# Supabase — public values (safe to expose in client bundle via VITE_ prefix)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_SUPABASE_PROJECT_ID=your-project-id

# Supabase — server-side aliases (same values as above, used in SSR)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase service role key — SECRET, server-only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Brevo (email) — SECRET, server-only
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=you@example.com
BREVO_SENDER_NAME=Your Company
BREVO_TEAM_EMAIL=team@example.com
BREVO_COMPANY_NAME=Your Company

# SEO — your live production domain (https, no trailing slash).
# Used for canonical URLs, Open Graph tags and the XML sitemap.
VITE_SITE_URL=https://www.buddiezholidays.com
